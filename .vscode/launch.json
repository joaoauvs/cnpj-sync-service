{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pipeline: info (mostra snapshot)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["info"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: tabelas de referência",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["run", "--reference-only"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: Empresas (todas as partições)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["run", "--groups", "Empresas", "--download-workers", "4"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: Socios",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["run", "--groups", "Socios"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: COMPLETO (todos os grupos)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["run", "--download-workers", "4", "--process-workers", "4"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: listar snapshots",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["list-snapshots"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline: download-only referências",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["download-only", "--reference-only"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
