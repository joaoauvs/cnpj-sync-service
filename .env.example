# Credenciais PostgreSQL
# Copie este arquivo para .env e preencha com suas credenciais reais

# Opção 1: URL completa (tem prioridade sobre as variáveis individuais abaixo)
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Opção 2: variáveis individuais
DB_SERVER=seu-host-postgres
DB_PORT=5432             # opcional — padrão: 5432
DB_DATABASE=seu-banco
DB_USERNAME=seu-usuario
DB_PASSWORD=sua-senha

# Aliases alternativos (usados se DB_USERNAME/DB_PASSWORD não estiverem definidos)
# POSTGRES_USER=seu-usuario
# POSTGRES_PASSWORD=sua-senha

# Comportamento do serviço
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
FORCE_SYNC=false         # true → reprocessa mesmo snapshot já carregado
REUSE_PROCESSED=true     # true → reutiliza data/processed/ entre execuções
SNAPSHOT_DATE=           # vazio = snapshot mais recente; ex: 2026-04 ou 2026-04-01

# Token do WebDAV da Receita Federal (share público — só altere se o token mudar)
# RF_SHARE_TOKEN=YggdBLfdninEJX9
